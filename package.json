{
  "name": "xq-fitness-write-service",
  "version": "2.1.0",
  "description": "Unified read and write API for XQ Fitness",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --config jest.config.unit.js --coverage",
    "build:client": "tsc -p generated-clients/write-service/tsconfig.json && tsc -p generated-clients/write-service/tsconfig.esm.json",
    "test:component": "yarn build:client && jest --config jest.config.component.js --runInBand",
    "test:component:local": "yarn build:client && API_BASE_URL=http://localhost:8080/xq-fitness-write-service/api/v1 HEALTH_CHECK_URL=http://localhost:8080/xq-fitness-write-service/health jest --config jest.config.component.js --runInBand",
    "test:component:watch": "yarn build:client && jest --config jest.config.component.js --watch",
    "test:component:ci": "yarn build:client && jest --config jest.config.component.js --runInBand --ci --reporters=default --reporters=jest-junit",
    "test:all": "yarn test:unit && yarn test:component",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "generate:client": "./scripts/generate-api-client.sh write-service",
    "clean:clients": "rm -rf generated-clients/"
  },
  "keywords": [
    "fitness",
    "workout",
    "api"
  ],
  "author": "XQ Fitness Team",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "pg": "^8.16.3",
    "pg-pool": "^3.6.1"
  },
  "devDependencies": {
    "@chauhaidang/xq-harness-common-kit": "0.1.0",
    "@chauhaidang/xq-test-utils": "1.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/joi": "^17.2.2",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/wait-on": "^5.3.4",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "commander": "^14.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.0",
    "ts-node": "latest",
    "typescript": "^5.5.4",
    "wait-on": "^8.0.1",
    "xq-fitness-write-client": "file:./generated-clients/write-service"
  },
  "jest-junit": {
    "outputDirectory": "./test/component/tsr",
    "outputName": "junit.xml",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › ",
    "usePathForSuiteName": "true"
  },
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae"
}
